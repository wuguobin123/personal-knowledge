# --------------------------
# Runtime / Auth
# --------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
AUTH_SECRET="change-this-long-random-secret"
# Optional: true | false. Empty means auto (https in production only).
COOKIE_SECURE=""

# --------------------------
# Database (Docker Compose)
# --------------------------
MYSQL_ROOT_PASSWORD="change-root-password"
MYSQL_DATABASE="blog_db"
MYSQL_USER="blog_user"
MYSQL_PASSWORD="change-db-password"

# Optional: expose nginx and mysql ports on host
NGINX_PORT="80"
MYSQL_PORT="3306"
MYSQL_BIND_ADDRESS="127.0.0.1"

# Optional: switch DB host/port (used by app in Docker)
# Default DB_HOST is "mysql" (internal compose service)
DB_HOST="mysql"
DB_PORT="3306"

# --------------------------
# Docker images (optional)
# --------------------------
# Default pulls from Docker Hub.
# If you use Aliyun accelerator endpoint, configure Docker daemon mirror
# (do NOT put that endpoint into NODE_IMAGE/MYSQL_IMAGE/NGINX_IMAGE):
#   /etc/docker/daemon.json -> {"registry-mirrors":["https://him7zrbc.mirror.aliyuncs.com"]}
# If you cannot change daemon config, you can set explicit mirror images, e.g.:
#   NODE_IMAGE="docker.1ms.run/library/node:20-alpine"
#   MYSQL_IMAGE="docker.1ms.run/library/mysql:8.0"
#   NGINX_IMAGE="docker.1ms.run/library/nginx:1.21-alpine"
NODE_IMAGE="node:20-alpine"
MYSQL_IMAGE="mysql:8.0"
NGINX_IMAGE="nginx:1.21-alpine"
# Limit Node heap during docker build to reduce OOM risk on small servers.
NODE_MAX_OLD_SPACE_SIZE="768"

# --------------------------
# Local non-Docker development
# --------------------------
DATABASE_URL="mysql://blog_user:change-db-password@127.0.0.1:3306/blog_db"

# --------------------------
# Upload storage
# --------------------------
# local | oss
STORAGE_PROVIDER="local"

# OSS config (required when STORAGE_PROVIDER=oss)
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET="your-bucket-name"
OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
# Optional: custom domain, e.g. https://img.example.com
OSS_PUBLIC_URL=""

# --------------------------
# AI News Scheduler
# --------------------------
# Every day at 07:00 (timezone below) fetches AI news + high-star GitHub AI repos.
AI_NEWS_TIMEZONE="Asia/Shanghai"
AI_NEWS_RUN_AT="07:00"
AI_NEWS_RUN_ON_START="false"
AI_NEWS_CHECK_INTERVAL_SECONDS="60"
AI_NEWS_RETRY_COOLDOWN_SECONDS="900"
AI_NEWS_MAX_NEWS_ITEMS="25"
AI_NEWS_MAX_GITHUB_ITEMS="20"
AI_NEWS_FETCH_TIMEOUT_MS="15000"
# Optional: increase GitHub API rate limit.
GITHUB_TOKEN=""

# --------------------------
# AI / SiliconFlow (LangChain)
# --------------------------
SILICONFLOW_API_KEY="sk-xxxx"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-R1-Distill-Qwen-32B"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  category    String   @default("未分类") @db.VarChar(80)
  tags        Json?
  sourceType  ArticleSourceType @default(ORIGINAL)
  sourceDetail String? @db.VarChar(500)
  excerpt     String   @db.VarChar(300)
  content     String   @db.LongText
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([category])
  @@index([sourceType])
}

model AiNewsItem {
  id         Int            @id @default(autoincrement())
  title      String         @db.VarChar(300)
  summary    String?        @db.VarChar(1000)
  url        String         @db.VarChar(500)
  source     String         @db.VarChar(80)
  category   AiNewsCategory @default(GENERAL_NEWS)
  externalId String?        @db.VarChar(191)
  stars      Int?
  language   String?        @db.VarChar(20)
  tags       Json?
  newsDate   DateTime       @db.Date
  fetchedAt  DateTime       @default(now())
  canPublish Boolean        @default(false)
  isDeleted  Boolean        @default(false)
  deletedAt  DateTime?
  raw        Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([source, url])
  @@index([newsDate, category])
  @@index([canPublish, isDeleted, newsDate])
  @@index([source, externalId])
}

enum ArticleSourceType {
  ORIGINAL
  CRAWLER
  TRANSCRIPT
}

enum AiNewsCategory {
  GENERAL_NEWS
  MODEL_RELEASE
  GITHUB_PROJECT
}

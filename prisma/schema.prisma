generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  category    String   @default("未分类") @db.VarChar(80)
  tags        Json?
  sourceType  ArticleSourceType @default(ORIGINAL)
  sourceDetail String? @db.VarChar(500)
  excerpt     String   @db.VarChar(300)
  content     String   @db.LongText
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([category])
  @@index([sourceType])
}

model AiNewsItem {
  id         Int            @id @default(autoincrement())
  title      String         @db.VarChar(300)
  summary    String?        @db.VarChar(1000)
  url        String         @db.VarChar(500)
  source     String         @db.VarChar(80)
  category   AiNewsCategory @default(GENERAL_NEWS)
  externalId String?        @db.VarChar(191)
  stars      Int?
  language   String?        @db.VarChar(20)
  tags       Json?
  newsDate   DateTime       @db.Date
  fetchedAt  DateTime       @default(now())
  canPublish Boolean        @default(false)
  isDeleted  Boolean        @default(false)
  deletedAt  DateTime?
  raw        Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([source, url])
  @@index([newsDate, category])
  @@index([canPublish, isDeleted, newsDate])
  @@index([source, externalId])
}

model QaSkill {
  id          Int           @id @default(autoincrement())
  skillKey    String        @unique @db.VarChar(120)
  label       String        @db.VarChar(120)
  description String        @db.VarChar(400)
  instruction String        @db.LongText
  modeHint    QaSkillMode   @default(AUTO)
  source      QaSkillSource @default(MANUAL)
  githubUrl   String?       @db.VarChar(500)
  stars       Int?
  isEnabled   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isEnabled, createdAt])
  @@index([source, stars])
}

model QaMcpModule {
  id            Int            @id @default(autoincrement())
  moduleKey     String         @unique @db.VarChar(120)
  label         String         @db.VarChar(120)
  description   String         @db.VarChar(400)
  transport     QaMcpTransport @default(STREAMABLE_HTTP)
  endpointUrl   String         @db.VarChar(500)
  headers       Json?
  connectionConfig Json?
  keywordHints  Json?
  toolAllowlist Json?
  modeHint      QaSkillMode    @default(AUTO)
  isEnabled     Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([isEnabled, createdAt])
}

model QaConversation {
  id            Int                     @id @default(autoincrement())
  userId        String                  @db.VarChar(120)
  title         String                  @db.VarChar(200)
  status        QaConversationStatus    @default(ACTIVE)
  mode          QaSkillMode             @default(AUTO)
  skillId       String                  @default("none") @db.VarChar(120)
  meta          Json?
  messageCount  Int                     @default(0)
  lastMessageAt DateTime                @default(now())
  archivedAt    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  messages      QaConversationMessage[]

  @@index([userId, status, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([createdAt])
}

model QaConversationMessage {
  id             Int                       @id @default(autoincrement())
  conversationId Int
  parentMessageId Int?
  userId         String                    @db.VarChar(120)
  role           QaConversationMessageRole
  status         QaConversationMessageStatus @default(COMPLETED)
  content        String                    @db.LongText
  reasoning      String?                   @db.LongText
  mode           QaSkillMode               @default(AUTO)
  skillId        String                    @default("none") @db.VarChar(120)
  provider       String?                   @db.VarChar(80)
  model          String?                   @db.VarChar(160)
  finishReason   String?                   @db.VarChar(80)
  promptTokens   Int?
  completionTokens Int?
  totalTokens    Int?
  latencyMs      Int?
  errorMessage   String?                   @db.VarChar(1000)
  meta           Json?
  createdAt      DateTime                  @default(now())
  conversation   QaConversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentMessage  QaConversationMessage?    @relation("QaConversationMessageParent", fields: [parentMessageId], references: [id], onDelete: SetNull)
  childMessages  QaConversationMessage[]   @relation("QaConversationMessageParent")

  @@index([conversationId, createdAt])
  @@index([conversationId, role, createdAt])
  @@index([conversationId, status, createdAt])
  @@index([userId, createdAt])
  @@index([parentMessageId])
}

enum ArticleSourceType {
  ORIGINAL
  CRAWLER
  TRANSCRIPT
}

enum AiNewsCategory {
  GENERAL_NEWS
  MODEL_RELEASE
  GITHUB_PROJECT
}

enum QaSkillMode {
  AUTO
  BLOG
  WEB
}

enum QaSkillSource {
  MANUAL
  GITHUB
}

enum QaMcpTransport {
  STREAMABLE_HTTP
  SSE
  STDIO
}

enum QaConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum QaConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum QaConversationMessageStatus {
  COMPLETED
  ERROR
}
